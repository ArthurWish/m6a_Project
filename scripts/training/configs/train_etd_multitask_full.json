  "struct_min_sep": 4,
  "bucket_boundaries": "1024,2048,4096,8192,12000",
  "ablate_no_condition": false,
  "ablate_no_dirichlet": false,
  "ablate_no_struct": false,
  "seed": 42,
  "device": "cuda",
  "amp": true,
